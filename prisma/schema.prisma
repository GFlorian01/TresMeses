generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Usuario (sincronizado con Supabase Auth) ───
model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cycles         Cycle[]
  habits         Habit[]
  dailyEntries   DailyEntry[]
  weeklyReviews  WeeklyReview[]

  @@map("users")
}

// ─── Ciclo de 12 semanas ───
model Cycle {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  goals     String[] // metas del ciclo como texto
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyReviews WeeklyReview[]

  @@map("cycles")
}

// ─── Hábitos configurables ───
model Habit {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String   // "Tender cama", "Estiramientos", etc.
  icon      String?  // emoji o icono
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  checks HabitCheck[]

  @@map("habits")
}

// ─── Entrada diaria (1 por día por usuario) ───
model DailyEntry {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  date           DateTime @db.Date
  isGymDay       Boolean  @default(false)
  isRecoveryDay  Boolean  @default(false)
  readingMinutes Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitChecks HabitCheck[]
  meals       MealEntry[]

  @@unique([userId, date])
  @@map("daily_entries")
}

// ─── Check de hábito (sí/no por hábito por día) ───
model HabitCheck {
  id           String   @id @default(uuid()) @db.Uuid
  dailyEntryId String   @db.Uuid
  habitId      String   @db.Uuid
  completed    Boolean  @default(false)
  createdAt    DateTime @default(now())

  dailyEntry DailyEntry @relation(fields: [dailyEntryId], references: [id], onDelete: Cascade)
  habit      Habit      @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([dailyEntryId, habitId])
  @@map("habit_checks")
}

// ─── Registro de comida ───
enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model MealEntry {
  id           String   @id @default(uuid()) @db.Uuid
  dailyEntryId String   @db.Uuid
  mealType     MealType
  completed    Boolean  @default(false)
  description  String?  // nombre del platillo o ingredientes
  createdAt    DateTime @default(now())

  dailyEntry DailyEntry @relation(fields: [dailyEntryId], references: [id], onDelete: Cascade)

  @@unique([dailyEntryId, mealType])
  @@map("meal_entries")
}

// ─── Revisión semanal ───
model WeeklyReview {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  cycleId        String   @db.Uuid
  weekNumber     Int      // 1-12
  score          Float?   // % de ejecución calculado
  reflection     String?  // texto libre
  causeAnalysis  String?  // análisis cuando score < 85%
  loadAdjustment String?  // reajuste para la siguiente semana
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle Cycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, weekNumber])
  @@map("weekly_reviews")
}
